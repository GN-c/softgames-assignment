{
  "name": "pixi-project",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "npm run dev",
    "prebuild": "assetpack",
    "build": "npm run lint && tsc && vite build",
    "lint": "eslint .",
    "watch:assetpack": "assetpack -w",
    "dev": "vite",
    "download-cards": "npx download-cards 36 raw-assets/ace-of-shadows{m}/atlas{tps}"
  },
  "bin": {
    "download-cards": "bin/download-cards.mjs"
  },
  "dependencies": {
    "nanoid": "^5.1.7",
    "pixi.js": "^8.8.1"
  },
  "devDependencies": {
    "@assetpack/core": "^1.7.0",
    "@eslint/js": "^9.21.0",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-prettier": "^5.2.6",
    "prettier": "^3.5.3",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.25.0",
    "vite": "^6.2.0"
  }
}
